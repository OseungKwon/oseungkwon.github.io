---
import Layout from '../layouts/Layout.astro';

const BASE = import.meta.env.BASE_URL;

const channels = [
  {
    label: 'GitHub',
    value: 'github.com/oseungkwon',
    href: 'https://github.com/oseungkwon',
    external: true,
  },
  {
    label: 'Email',
    value: '00osos@naver.com',
    href: 'mailto:00osos@naver.com',
    external: false,
  },
  {
    label: 'RSS',
    value: '새 글 구독하기',
    href: `${BASE}rss.xml`,
    external: false,
  },
];
---

<Layout
  title="Contact"
  description="프론트엔드 개발자 자몽에게 연락하는 방법 — GitHub, 이메일, RSS 구독."
>
  <section class="pt-8 sm:pt-12">
    <p class="font-mono text-xs font-medium uppercase tracking-[0.18em] text-token-accent">
      Say hello
    </p>

    <div class="mt-8 sm:mt-10">
      <div class="max-w-2xl">
        <h1
          class="text-4xl font-bold leading-[1.12] tracking-tight text-token-primary break-keep sm:text-5xl"
        >
          권오승
        </h1>
        <p class="mt-3 text-[15px] font-medium tracking-tight text-token-link">
          라이브러리를 뜯어보고 구조를 고민하는 프론트엔드 개발자입니다.
        </p>
        <p class="mt-5 text-[17px] leading-relaxed text-token-secondary break-keep">
          라이브러리가 실제로 어떻게 동작하는지 내부를 뜯어보고, 프론트엔드
          아키텍처를 어떻게 설계할지 고민한 기록을 이곳에 남깁니다. 생산성을
          높이는 툴을 만들거나 개선하는 일에도 관심이 많습니다. 글에 대한 의견이나
          함께 이야기 나누고 싶은 주제가 있다면 아래로 연락 주세요.
        </p>
      </div>
    </div>
  </section>

  <section class="mt-14 sm:mt-16">
    <div class="flex items-baseline gap-3">
      <h2 class="font-mono text-xs font-bold uppercase tracking-[0.16em] text-token-secondary">
        Reach out
      </h2>
      <span class="font-mono text-xs font-bold text-token-accent"
        >{channels.length}</span
      >
    </div>

    <ul class="mt-4 flex flex-col gap-3">
      {
        channels.map((channel) => (
          <li>
            <a
              href={channel.href}
              target={channel.external ? '_blank' : undefined}
              rel={channel.external ? 'noopener noreferrer' : undefined}
              class="channel group surface flex items-center justify-between gap-6 rounded-2xl px-5 py-4 transition duration-200 hover:-translate-y-0.5 hover:bg-token-hover sm:px-6 sm:py-5"
            >
              <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-6">
                <span class="w-16 shrink-0 font-mono text-[11px] font-medium uppercase tracking-widest text-token-date">
                  {channel.label}
                </span>
                <span class="text-lg font-semibold tracking-tight text-token-primary transition-colors duration-200 group-hover:text-token-link sm:text-xl">
                  {channel.value}
                </span>
              </div>
              <svg
                class="h-5 w-5 shrink-0 text-token-tertiary transition-all duration-200 group-hover:translate-x-1 group-hover:text-token-link"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

<style>
  .channel:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 1rem;
  }
</style>

<script>
  // 마우스 클릭 뒤 포커스 아웃라인이 남지 않게 blur (키보드 포커스는 유지).
  function initChannelBlur() {
    document.querySelectorAll<HTMLElement>('.channel').forEach((el) => {
      el.addEventListener('pointerup', () => el.blur());
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initChannelBlur);
  } else {
    initChannelBlur();
  }
</script>
