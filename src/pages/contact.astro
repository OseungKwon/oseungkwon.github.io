---
import Layout from '../layouts/Layout.astro';

const BASE = import.meta.env.BASE_URL;

// 연락 채널 — PostListItem의 행 호버 패턴을 계승한다.
const channels = [
  {
    label: 'GitHub',
    value: 'github.com/oseungkwon',
    href: 'https://github.com/oseungkwon',
    external: true,
  },
  {
    label: 'Email',
    value: '00osos@naver.com',
    href: 'mailto:00osos@naver.com',
    external: false,
  },
  {
    label: 'RSS',
    value: '새 글 구독하기',
    href: `${BASE}rss.xml`,
    external: false,
  },
];
---

<Layout
  title="Contact"
  description="프론트엔드 개발자 자몽에게 연락하는 방법 — GitHub, 이메일, RSS 구독."
>
  <!-- 마이크로 라벨: 홈의 '최근 글 + 개수' 패턴을 계승 -->
  <section class="pt-6 sm:pt-10">
    <div class="flex items-baseline gap-3">
      <h1
        class="text-xs font-bold uppercase tracking-[0.18em] text-token-secondary"
      >
        Contact
      </h1>
      <span
        class="inline-block h-1.5 w-1.5 rounded-full bg-token-accent"
        aria-hidden="true"></span>
    </div>

    <!-- 프로필: 자른 자몽이 프로필 사진을 대신한다 -->
    <div
      class="mt-8 flex flex-col gap-8 sm:mt-10 sm:flex-row sm:items-start sm:gap-10"
    >
      <!-- 시그니처: 8조각 자몽. 로드 시 조각이 순차로 켜진다(peel-open). -->
      <svg
        id="contact-grapefruit"
        class="h-24 w-24 shrink-0 sm:h-28 sm:w-28"
        viewBox="0 0 128 128"
        aria-hidden="true"
        role="img"
      >
        <g
          stroke="var(--color-grapefruit-300)"
          stroke-width="2.4"
          stroke-linejoin="round"
        >
          <path
            class="cw"
            style="--i:0"
            d="M64 64 L64 19 A45 45 0 0 1 95.82 32.18 Z"></path>
          <path
            class="cw"
            style="--i:1"
            d="M64 64 L95.82 32.18 A45 45 0 0 1 109 64 Z"></path>
          <path
            class="cw"
            style="--i:2"
            d="M64 64 L109 64 A45 45 0 0 1 95.82 95.82 Z"></path>
          <path
            class="cw"
            style="--i:3"
            d="M64 64 L95.82 95.82 A45 45 0 0 1 64 109 Z"></path>
          <path
            class="cw"
            style="--i:4"
            d="M64 64 L64 109 A45 45 0 0 1 32.18 95.82 Z"></path>
          <path
            class="cw"
            style="--i:5"
            d="M64 64 L32.18 95.82 A45 45 0 0 1 19 64 Z"></path>
          <path
            class="cw"
            style="--i:6"
            d="M64 64 L19 64 A45 45 0 0 1 32.18 32.18 Z"></path>
          <path
            class="cw"
            style="--i:7"
            d="M64 64 L32.18 32.18 A45 45 0 0 1 64 19 Z"></path>
        </g>
        <circle cx="64" cy="64" r="5" fill="var(--color-grapefruit-300)"
        ></circle>
      </svg>

      <div class="max-w-xl">
        <h2
          class="text-4xl font-bold leading-[1.15] tracking-tight text-token-primary break-keep sm:text-5xl"
        >
          권오승
        </h2>
        <p class="mt-3 text-[15px] font-medium tracking-tight text-token-link">
          라이브러리를 뜯어보고 구조를 고민하는 프론트엔드 개발자입니다.
        </p>
        <p
          class="mt-5 text-[17px] leading-relaxed text-token-secondary break-keep"
        >
          라이브러리가 실제로 어떻게 동작하는지 내부를 뜯어보고, <br
          />프론트엔드 아키텍처를 어떻게 설계할지 고민한 기록을 이곳에 남깁니다.<br
          />
          생산성을 높이는 툴을 만들거나 개선하는 일에도 관심이 많습니다. <br />
          글에 대한 의견이나 함께 이야기 나누고 싶은 주제가 있다면 아래로 연락 주세요.
        </p>
      </div>
    </div>
  </section>

  <!-- 연락 채널: 헤어라인 행 + 호버 미끄러짐 -->
  <section class="mt-16 sm:mt-20">
    <div class="flex items-baseline gap-3">
      <h2
        class="text-xs font-bold uppercase tracking-[0.18em] text-token-secondary"
      >
        Reach out
      </h2>
      <span class="text-xs font-bold text-token-accent">{channels.length}</span>
    </div>

    <ul class="mt-2 flex flex-col border-t-[0.5px] border-token-primary">
      {
        channels.map((channel) => (
          <li>
            <a
              href={channel.href}
              target={channel.external ? '_blank' : undefined}
              rel={channel.external ? 'noopener noreferrer' : undefined}
              class="channel group flex items-center justify-between gap-6 border-b-[0.5px] border-token-primary py-6 transition-colors duration-200 hover:bg-token-hover hover:border-token-hover sm:py-7"
            >
              <div class="flex flex-col gap-1.5 sm:flex-row sm:items-baseline sm:gap-6">
                <span class="w-20 shrink-0 text-[11px] font-bold uppercase tracking-widest text-token-date">
                  {channel.label}
                </span>
                <span class="text-lg font-semibold tracking-tight text-token-primary transition-colors duration-200 group-hover:text-token-link sm:text-xl">
                  {channel.value}
                </span>
              </div>
              <svg
                class="channel-arrow h-5 w-5 shrink-0 text-token-tertiary transition-all duration-200 group-hover:translate-x-1 group-hover:text-token-accent"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"
                />
              </svg>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

<style>
  /* 8조각은 기본적으로 코랄로 채워지되, 로드 시 순차로 나타난다(peel-open).
     헤더의 조각 모티프를 그대로 재사용해 사이트 정체성을 잇는다. */
  .cw {
    fill: var(--color-grapefruit-400);
    transform-box: fill-box;
    transform-origin: 64px 64px;
  }

  @media (prefers-reduced-motion: no-preference) {
    /* 준비 전에는 접힌 상태로 숨겨 두고, data-ready가 붙으면 순차로 펼친다. */
    #contact-grapefruit:not([data-ready]) .cw {
      opacity: 0;
    }
    #contact-grapefruit[data-ready] .cw {
      animation: peel-open 0.5s cubic-bezier(0.22, 1, 0.36, 1) backwards;
      animation-delay: calc(var(--i) * 0.07s);
    }
  }

  @keyframes peel-open {
    from {
      opacity: 0;
      transform: scale(0.6) rotate(-8deg);
    }
    to {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
  }

  /* 키보드 포커스: 사이트 액센트로 또렷하게 */
  .channel:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
    border-radius: 0.5rem;
  }
</style>

<script>
  // 자몽 조각을 순차로 펼치는 리빌. 첫 페인트 이후로 미뤄 진입 렌더와 경쟁하지 않게 한다.
  function initContactGrapefruit() {
    const svg = document.getElementById('contact-grapefruit');
    if (!svg) return;
    requestAnimationFrame(() => {
      svg.dataset.ready = 'true';
    });
  }

  // 마우스 클릭 뒤 포커스 아웃라인이 남지 않게 blur 한다.
  // pointerup은 키보드로는 발생하지 않으므로 키보드 포커스 링은 그대로 유지된다.
  function initChannelBlur() {
    document.querySelectorAll<HTMLElement>('.channel').forEach((el) => {
      el.addEventListener('pointerup', () => el.blur());
    });
  }

  function init() {
    initContactGrapefruit();
    initChannelBlur();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
