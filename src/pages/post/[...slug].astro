---
import { type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { getPublishedPosts } from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={post.data.heroImage?.src}
  imageWidth={post.data.heroImage?.width}
  imageHeight={post.data.heroImage?.height}
  article={true}
  publishedTime={post.data.pubDate.toISOString()}
  modifiedTime={post.data.updatedDate?.toISOString()}
  tags={post.data.tags}
>
  <div class="relative">
    <article class="mx-auto max-w-3xl">
      <div class="mb-12 text-center">
        <div
          class="mb-4 text-sm font-bold uppercase tracking-widest text-token-date"
        >
          {
            post.data.pubDate.toLocaleDateString('en-us', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })
          }
        </div>
        <h1
          class="mb-6 text-4xl font-bold tracking-tight text-token-primary sm:text-5xl break-keep break-words"
          style="scroll-margin-top: 4rem;"
        >
          {post.data.title}
        </h1>
        <hr
          class="mx-auto my-8 h-1 w-16 rounded-full border-0 bg-token-accent"
        />
      </div>

      {
        post.data.heroImage && (
          <div class="mb-12 overflow-hidden rounded-3xl shadow-sm">
            <Image
              src={post.data.heroImage}
              alt={post.data.title}
              widths={[768, 1152, 1536]}
              sizes="(min-width: 768px) 768px, 100vw"
              format="webp"
              quality={80}
              loading="eager"
              fetchpriority="high"
              class="w-full object-cover"
            />
          </div>
        )
      }

      <div class="prose prose-lg prose-gray mx-auto">
        <Content />
      </div>
    </article>

    <!-- Table of Contents (우측 고정) -->
    <TableOfContents />
  </div>
</Layout>
