---
import Layout from '../layouts/Layout.astro';
import PostListItem from '../components/PostListItem.astro';
import FeaturedPost from '../components/FeaturedPost.astro';
import { getPublishedPosts } from '../utils/posts';

const posts = (await getPublishedPosts()).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' });

const [featured, ...rest] = posts;
---

<Layout>
  <!-- 히어로: 한 줄 소개. 라이브러리 내부 분석과 아키텍처 설계라는 두 축을
       병렬 문장으로 담담하게 말한다. 무게는 아래 카드로. -->
  <section class="pt-7 pb-1 sm:pt-11">
    <h1
      class="max-w-4xl text-[17px] font-semibold leading-[1.6] tracking-tight text-token-primary break-keep sm:text-[19px]"
    >
      라이브러리가 실제로 어떻게 동작하는지 내부를 뜯어보고, 프론트엔드
      아키텍처를 어떻게 설계할지 고민합니다
    </h1>
  </section>

  <!-- 최신 글: 카드형 featured. '지난 글'과 짝을 이루는 라벨을 달아
       히어로에 논지를 넘긴 뒤 카드는 시퀀스의 첫 항목으로 읽히게 한다. -->
  {
    featured && (
      <div class="mt-9 sm:mt-12">
        <h2 class="mb-4 font-mono text-xs font-bold uppercase tracking-[0.18em] text-token-secondary">
          최신 글
        </h2>
        <div class="featured-halo featured-reveal">
          <FeaturedPost
            title={featured.data.title}
            description={featured.data.description}
            date={formatDate(featured.data.pubDate)}
            href={`${import.meta.env.BASE_URL}post/${featured.slug}/`}
            category={featured.data.category}
            tags={featured.data.tags}
          />
        </div>
      </div>
    )
  }

  <div class="mt-10 border-t-[0.5px] border-token-primary pt-6 sm:mt-14">
    <div class="flex items-baseline gap-3">
      <h2
        class="font-mono text-xs font-bold uppercase tracking-[0.18em] text-token-secondary"
      >
        지난 글
      </h2>
      <span class="font-mono text-xs font-bold text-token-accent">{rest.length}</span>
    </div>
    <div class="mt-4 flex flex-col gap-3">
      {
        rest.map((post) => (
          <PostListItem
            title={post.data.title}
            description={post.data.description}
            date={formatDate(post.data.pubDate)}
            image={post.data.heroImage}
            href={`${import.meta.env.BASE_URL}post/${post.slug}/`}
            category={post.data.category}
            tags={post.data.tags}
          />
        ))
      }
    </div>
  </div>
</Layout>
