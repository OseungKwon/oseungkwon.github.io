---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PostListItem from '../components/PostListItem.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout>
  <!-- 히어로: 자몽 정체성 + 콘텐츠 thesis -->
  <section class="pt-6 pb-2 sm:pt-10">
    <h1
      class="max-w-2xl text-4xl font-bold leading-[1.15] tracking-tight text-token-primary break-keep sm:text-5xl"
    >
      코드를 뜯어보고<br />구조를 고민한 기록.
    </h1>
    <p
      class="mt-5 max-w-xl text-[17px] leading-relaxed text-token-secondary break-keep"
    >
      라이브러리 내부 동작부터 프론트엔드 아키텍처 설계까지, 직접 파고든 내용을
      정리합니다.
    </p>
  </section>

  <div class="mt-10 border-t-[0.5px] border-token-primary pt-6 sm:mt-20">
    <div class="flex items-baseline gap-3">
      <h2
        class="text-xs font-bold uppercase tracking-[0.18em] text-token-secondary"
      >
        최근 글
      </h2>
      <span class="text-xs font-bold text-token-accent">{posts.length}</span>
    </div>
    <div class="flex flex-col">
      {
        posts.map((post) => (
          <PostListItem
            title={post.data.title}
            description={post.data.description}
            date={post.data.pubDate.toLocaleDateString('en-us', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })}
            image={post.data.heroImage}
            href={`${import.meta.env.BASE_URL}post/${post.slug}/`}
            category={post.data.category}
            tags={post.data.tags}
          />
        ))
      }
    </div>
  </div>
</Layout>
