---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import PostThumbFallback from './PostThumbFallback.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  image?: ImageMetadata;
  href: string;
  category: 'book' | 'tech';
  tags: string[];
}

const { title, description, date, image, href, category } = Astro.props;

const categoryLabels = { book: 'Book', tech: 'Tech' };
---

<a
  href={href}
  class="press surface flex items-center gap-4 rounded-2xl p-3.5 sm:gap-5 sm:p-4"
>
  <div
    class="h-14 w-14 shrink-0 overflow-hidden rounded-xl bg-token-image sm:h-16 sm:w-16"
  >
    {
      image ? (
        <Image
          src={image}
          alt={title}
          widths={[128, 192]}
          sizes="64px"
          format="webp"
          quality={80}
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover"
        />
      ) : (
        <PostThumbFallback label={categoryLabels[category]} />
      )
    }
  </div>

  <div class="min-w-0 flex-1">
    <div
      class="flex items-center gap-2 font-mono text-[11px] tracking-wide text-token-date"
    >
      <span class="uppercase tracking-wider">{categoryLabels[category]}</span>
      <span aria-hidden="true">·</span>
      <span>{date}</span>
    </div>
    <h3
      class="mt-1 truncate text-[15px] font-semibold tracking-tight text-token-primary sm:text-base"
    >
      {title}
    </h3>
    <p
      class="mt-0.5 hidden truncate text-[13px] text-token-secondary sm:block"
    >
      {description}
    </p>
  </div>

  <svg
    class="hidden h-5 w-5 shrink-0 text-token-tertiary sm:block"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path d="M9 6l6 6-6 6"></path>
  </svg>
</a>
