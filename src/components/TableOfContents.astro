---
// TableOfContents component - 본문 헤딩 기반 목차 (우측 고정)
---

<aside
  id="table-of-contents"
  class="sticky top-24 hidden max-h-[calc(100vh-8rem)] w-52 shrink-0 self-start overflow-y-auto toc-scrollbar xl:block"
>
  <nav>
    <p class="toc-label">목차</p>
    <ul id="toc-list" class="toc-rail"></ul>
  </nav>
</aside>

<script>
  function initTableOfContents() {
    const toc = document.getElementById('table-of-contents');
    const tocList = document.getElementById('toc-list');
    // 페이지 제목(article 직속 h1)은 제외하고 본문(.prose) 헤딩만 대상으로 한다.
    const content = document.querySelector('article .prose');

    if (!toc || !tocList || !content) return;

    const headings = Array.from(
      content.querySelectorAll('h1, h2, h3'),
    ) as HTMLElement[];

    if (headings.length === 0) {
      toc.style.display = 'none';
      return;
    }

    // 글마다 최상위 헤딩 레벨이 다르므로(h1 또는 h2), 문서 내 최소 레벨을
    // 기준으로 상대 깊이를 계산해 들여쓰기를 정규화한다.
    const levelOf = (el: HTMLElement) => Number(el.tagName[1]);
    const minLevel = Math.min(...headings.map(levelOf));

    const links: HTMLAnchorElement[] = [];

    headings.forEach((heading, index) => {
      if (!heading.id) heading.id = `heading-${index}`;

      const depth = Math.min(levelOf(heading) - minLevel, 2);

      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent || '';
      a.className = `toc-link toc-depth-${depth}`;

      a.addEventListener('click', (e) => {
        e.preventDefault();
        heading.scrollIntoView({ behavior: 'auto', block: 'start' });
        history.pushState(null, '', `#${heading.id}`);
      });

      li.appendChild(a);
      tocList.appendChild(li);
      links.push(a);
    });

    // 스크롤 시 활성 섹션 하이라이트
    let ticking = false;

    function updateActiveSection() {
      // 본문이 position:relative 컨테이너 안에 있어도 정확하도록 뷰포트 기준으로 판정
      let activeIndex = 0;
      headings.forEach((heading, i) => {
        if (heading.getBoundingClientRect().top <= 140) activeIndex = i;
      });

      links.forEach((link, i) => {
        link.classList.toggle('active', i === activeIndex);
      });

      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(updateActiveSection);
        ticking = true;
      }
    });

    updateActiveSection();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTableOfContents);
  } else {
    initTableOfContents();
  }
</script>

<style is:global>
  /* 목차 레이블 — 홈의 "최근 글" 라벨과 동일한 트래킹 스타일로 통일 */
  #table-of-contents .toc-label {
    margin: 0 0 0.875rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-tertiary);
  }

  /* 왼쪽 헤어라인 레일 */
  #table-of-contents .toc-rail {
    list-style: none;
    margin: 0;
    padding: 0;
    border-left: 1px solid var(--color-border-primary);
  }

  #table-of-contents .toc-link {
    display: block;
    margin-left: -1px; /* active 보더가 레일 위에 겹치도록 */
    border-left: 2px solid transparent;
    padding: 0.375rem 0.5rem 0.375rem 1rem;
    font-size: 0.8125rem;
    line-height: 1.45;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  /* 깊이별 들여쓰기 (레일 기준 상대 정규화) */
  #table-of-contents .toc-depth-0 {
    padding-left: 1rem;
    font-weight: 500;
    color: var(--color-text-primary);
  }
  #table-of-contents .toc-depth-1 {
    padding-left: 1.75rem;
  }
  #table-of-contents .toc-depth-2 {
    padding-left: 2.5rem;
    font-size: 0.75rem;
  }

  #table-of-contents .toc-link:hover {
    color: var(--color-text-primary);
  }

  /* 활성 항목 — 시그니처 자몽 액센트 (텍스트 + 레일 마커) */
  #table-of-contents .toc-link.active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    font-weight: 600;
  }

  /* 스크롤바 (디자인 토큰) */
  .toc-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .toc-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .toc-scrollbar::-webkit-scrollbar-thumb {
    background: var(--color-border-primary);
    border-radius: 2px;
  }
  .toc-scrollbar::-webkit-scrollbar-thumb:hover {
    background: var(--color-text-tertiary);
  }
</style>
