---
interface Props {
  wide?: boolean;
}
const { wide = false } = Astro.props;

const BASE = import.meta.env.BASE_URL;
const path = Astro.url.pathname.replace(/\/$/, '');
const base = BASE.replace(/\/$/, '');
const isHome = path === base;
const isContact = path === `${base}/contact`;
---

<header
  class:list={[
    'sticky top-3 z-50 mx-auto w-full px-4 sm:top-4 sm:px-6 lg:px-8',
    wide ? 'max-w-6xl' : 'max-w-5xl',
  ]}
>
  <nav
    class="surface vt-navbar flex items-center justify-between gap-3 rounded-full py-2 pr-2 pl-5 sm:pl-6"
  >
    <a
      href={BASE}
      class="text-[15px] font-extrabold tracking-tight text-token-primary sm:text-base"
      aria-label="자몽의 기술블로그 홈"
    >
      자몽의 기술블로그
    </a>

    <div class="flex items-center gap-0.5 sm:gap-1">
      <a
        href={BASE}
        aria-current={isHome ? 'page' : undefined}
        class:list={[
          'relative isolate rounded-full px-3.5 py-2 text-sm font-semibold transition-colors',
          isHome
            ? 'text-token-link'
            : 'text-token-nav hover:bg-token-hover hover:text-token-primary',
        ]}
      >
        {isHome && <span class="nav-pill-bg" aria-hidden="true" />}
        홈
      </a>
      <a
        href={`${BASE}contact/`}
        aria-current={isContact ? 'page' : undefined}
        class:list={[
          'relative isolate rounded-full px-3.5 py-2 text-sm font-semibold transition-colors',
          isContact
            ? 'text-token-link'
            : 'text-token-nav hover:bg-token-hover hover:text-token-primary',
        ]}
      >
        {isContact && <span class="nav-pill-bg" aria-hidden="true" />}
        Contact
      </a>
      <button
        id="dark-mode-toggle"
        class="grid h-9 w-9 shrink-0 cursor-pointer place-items-center rounded-full text-token-nav transition-colors hover:bg-token-hover hover:text-token-primary"
        aria-label="다크모드 토글"
      >
        <svg
          id="sun-icon"
          class="h-[18px] w-[18px] dark:hidden"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          viewBox="0 0 24 24"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
          ></path>
        </svg>
        <svg
          id="moon-icon"
          class="hidden h-[18px] w-[18px] dark:block"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          viewBox="0 0 24 24"
        >
          <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8Z"></path>
        </svg>
      </button>
    </div>
  </nav>
</header>
