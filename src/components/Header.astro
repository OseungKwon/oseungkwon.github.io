---

---

<header
  id="main-header"
  class="sticky top-0 z-50 w-full border-b-[0.5px] border-token-primary bg-token-header backdrop-blur-2xl transition-all supports-backdrop-filter:bg-token-header"
>
  <div
    class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6 lg:px-8"
  >
    <a
      href="/"
      class="flex items-center gap-2 group rounded-lg px-3 py-1.5 -mx-3 -my-1.5 transition-all duration-200 group-hover:bg-token-hover"
    >
      <svg
        id="grapefruit-progress"
        class="h-6 w-6 shrink-0"
        viewBox="0 0 128 128"
        aria-hidden="true"
        role="img"
      >
        <!-- 8조각 부채꼴: 스크롤 진행도에 따라 12시부터 시계방향으로 채워진다 -->
        <g
          stroke="var(--color-grapefruit-300)"
          stroke-width="2.4"
          stroke-linejoin="round"
        >
          <path class="gf-wedge" d="M64 64 L64 19 A45 45 0 0 1 95.82 32.18 Z"
          ></path>
          <path class="gf-wedge" d="M64 64 L95.82 32.18 A45 45 0 0 1 109 64 Z"
          ></path>
          <path class="gf-wedge" d="M64 64 L109 64 A45 45 0 0 1 95.82 95.82 Z"
          ></path>
          <path class="gf-wedge" d="M64 64 L95.82 95.82 A45 45 0 0 1 64 109 Z"
          ></path>
          <path class="gf-wedge" d="M64 64 L64 109 A45 45 0 0 1 32.18 95.82 Z"
          ></path>
          <path class="gf-wedge" d="M64 64 L32.18 95.82 A45 45 0 0 1 19 64 Z"
          ></path>
          <path class="gf-wedge" d="M64 64 L19 64 A45 45 0 0 1 32.18 32.18 Z"
          ></path>
          <path class="gf-wedge" d="M64 64 L32.18 32.18 A45 45 0 0 1 64 19 Z"
          ></path>
        </g>
        <circle cx="64" cy="64" r="5" fill="var(--color-grapefruit-300)"
        ></circle>
      </svg>
      <span
        class="text-xl font-bold tracking-tight text-token-primary transition-all duration-300 group-hover:text-token-secondary"
        >자몽의 기술블로그</span
      >
    </a>
    <nav class="flex items-center gap-4 sm:gap-8">
      <a
        href={`${import.meta.env.BASE_URL}contact/`}
        class="text-[15px] font-medium text-token-nav hover:text-token-primary transition-colors"
        >Contact</a
      >
      <button
        id="dark-mode-toggle"
        class="p-2 rounded-lg text-token-nav hover:text-token-primary hover:bg-token-hover transition-colors shrink-0"
        aria-label="다크모드 토글"
      >
        <svg
          id="sun-icon"
          class="w-5 h-5 hidden dark:block"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
          ></path>
        </svg>
        <svg
          id="moon-icon"
          class="w-5 h-5 dark:hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
          ></path>
        </svg>
      </button>
    </nav>
  </div>
</header>

<style>
  /* 부채꼴은 기본적으로 비어 있고(아웃라인만), 채워지면 부드러운 코랄로 */
  .gf-wedge {
    fill: transparent;
  }
  .gf-wedge.is-filled {
    fill: var(--color-grapefruit-400);
  }
  /* 전환은 초기화가 끝난(data-ready) 뒤에만 건다.
     페이지 진입 시 초기 채움이 애니메이션으로 쓸려 보이는 것을 막는다. */
  @media (prefers-reduced-motion: no-preference) {
    #grapefruit-progress[data-ready] .gf-wedge {
      transition: fill 0.4s ease;
    }
  }
</style>

<script>
  // 페이지 스크롤 진행도를 자몽 아이콘 8조각으로 시각화한다.
  function initGrapefruitProgress() {
    const svg = document.getElementById('grapefruit-progress');
    const wedges = svg
      ? svg.querySelectorAll<SVGPathElement>('.gf-wedge')
      : null;
    if (!svg || !wedges || !wedges.length) return;
    const total = wedges.length;

    // maxScroll은 레이아웃을 읽어야 하므로 스크롤마다 계산하지 않고 캐싱한다.
    // 스크롤 프레임에서는 window.scrollY만 읽어 리플로우를 피한다.
    let maxScroll = 0;
    let lastFilled = -1;
    let ticking = false;

    function measure() {
      const doc = document.documentElement;
      maxScroll = doc.scrollHeight - doc.clientHeight;
    }

    function render() {
      ticking = false;
      const progress = maxScroll > 0 ? window.scrollY / maxScroll : 0;
      const filled = Math.min(total, Math.max(0, Math.round(progress * total)));
      if (filled === lastFilled) return; // 조각 수가 그대로면 DOM을 건드리지 않는다

      // 처음엔 전체를, 이후엔 바뀐 구간의 조각만 토글한다.
      const start = lastFilled < 0 ? 0 : Math.min(filled, lastFilled);
      const end = lastFilled < 0 ? total : Math.max(filled, lastFilled);
      for (let i = start; i < end; i++) {
        wedges[i].classList.toggle('is-filled', i < filled);
      }
      lastFilled = filled;
    }

    function schedule() {
      if (!ticking) {
        ticking = true;
        window.requestAnimationFrame(render);
      }
    }

    // 레이아웃을 다시 재는 작업(measure)은 리플로우를 유발하므로 rAF로 묶는다.
    function remeasure() {
      measure();
      schedule();
    }

    window.addEventListener('scroll', schedule, { passive: true });
    window.addEventListener('resize', remeasure, { passive: true });
    // 폰트·이미지 로딩으로 문서 높이가 확정되면 한 번 더 잰다.
    // body에 붙던 ResizeObserver는 진입 시 반복 발화하며 레이아웃 스래싱을 일으켜 걷어냈다.
    window.addEventListener('load', remeasure, { passive: true });

    // 최초 계산과 렌더는 첫 페인트 이후로 미뤄 페이지 진입 렌더와 경쟁하지 않게 한다.
    window.requestAnimationFrame(() => {
      measure();
      render();
      // 초기 채움을 전환 없이 그린 뒤, 다음 프레임부터 전환을 허용한다.
      window.requestAnimationFrame(() => {
        svg.dataset.ready = 'true';
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGrapefruitProgress);
  } else {
    initGrapefruitProgress();
  }
</script>
