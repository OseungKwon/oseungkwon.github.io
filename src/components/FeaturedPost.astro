---
interface Props {
  title: string;
  description: string;
  date: string;
  href: string;
  category: 'book' | 'tech';
  tags: string[];
}

const { title, description, date, href, category, tags } = Astro.props;

const categoryLabels = { book: 'Book', tech: 'Tech' };
---

<!-- 시그니처: 사이트에서 유일하게 '유리(glass)' 질감을 쓰는 카드 -->
<a
  href={href}
  class="press glass flex flex-col rounded-3xl p-7 sm:p-8"
>
  <span
    class="mb-4 inline-flex w-fit items-center gap-2 rounded-full bg-token-accent-soft px-3 py-1.5 font-mono text-[11px] font-medium tracking-wide text-token-link"
  >
    <span aria-hidden="true">◆</span> Latest · {date}
  </span>

  <h2
    class="text-2xl font-bold leading-[1.25] tracking-tight text-token-primary break-keep sm:text-3xl"
  >
    {title}
  </h2>

  <p
    class="mt-3 text-[15px] leading-relaxed text-token-secondary break-keep line-clamp-3"
  >
    {description}
  </p>

  <div class="mt-5 flex flex-wrap items-center gap-1.5">
    <span
      class="rounded-full bg-token-category px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wider text-token-category"
    >
      {categoryLabels[category]}
    </span>
    {
      tags.slice(0, 4).map((tag) => (
        <span class="rounded-full border border-token-primary px-2.5 py-1 font-mono text-[11px] text-token-secondary">
          #{tag}
        </span>
      ))
    }
  </div>
</a>
